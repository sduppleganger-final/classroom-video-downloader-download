HOSTED_MODE=1
PORT=3000
PYTHON_BIN=python3
FFMPEG_LOCATION=
DOWNLOADS_DIR=/tmp/classroom-video-downloads

# Set this before sharing a hosted classroom demo link.
CLASSROOM_ACCESS_CODE=change-this-class-code

# Set this only when the frontend is hosted on a different origin from the backend.
# Example: PUBLIC_APP_ORIGIN=https://your-codex-site.example
PUBLIC_APP_ORIGIN=

# Hosted jobs are deleted after this many milliseconds.
DOWNLOAD_JOB_TTL_MS=3600000
DOWNLOAD_CLEANUP_INTERVAL_MS=300000
DOWNLOAD_MAX_CONCURRENT_JOBS=1

# Optional: stop extractor processes that run too long.
DOWNLOAD_TIMEOUT_MS=900000
